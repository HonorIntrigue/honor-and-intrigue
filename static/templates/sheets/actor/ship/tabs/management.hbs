<section class='tab scrollable {{tabs.management.id}}{{#if tabs.management.cssClass}} {{tabs.management.cssClass}}{{/if}}'
         data-group='{{tabs.management.group}}'
         data-tab='{{tabs.management.id}}'>
  <div class='tab-content'>
    <div class='item-list crew-duties'>
      <div class='item-list-header'>
        <span>{{localize 'HONOR_INTRIGUE.Actor.Sheet.Labels.Ship.CrewDuties'}}</span>
      </div>
      <ol class='item-list-items crew-duties-list'>
        {{#each duties as |duty|}}
          <li class='item crew-duties-list-item' data-duty='{{duty.key}}'>
            <div>
              <div class='item-image crew-duties-list-item-image'>
                <img src='{{duty.value.img}}' alt='{{duty.value.name}}'>
              </div>
              <div class='item-name' data-action='openCrewDuty'>
                <span>{{duty.value.name}}</span>
                <span class='crew-duties-item-duty {{#if duty.value}}subtitle{{/if}}'>{{duty.label}}</span>
              </div>
            </div>

            <div class='item-controls'>
              {{#if duty.value}}
                <a data-action='deleteCrewDuty' data-tooltip='HONOR_INTRIGUE.Actor.Sheet.Tooltips.Delete'>
                  <i class='fa-solid fa-trash'></i>
                </a>
              {{/if}}
            </div>
          </li>
        {{/each}}
      </ol>
    </div>

    {{> 'systems/honor-and-intrigue/templates/api/item-list.hbs'
      dataType='boon'
      items=boons
      title=(localize 'HONOR_INTRIGUE.Actor.Sheet.Labels.Character.Boons')
      wrapperClass='boons-list'
    }}

    {{> 'systems/honor-and-intrigue/templates/api/item-list.hbs'
      dataType='flaw'
      items=flaws
      title=(localize 'HONOR_INTRIGUE.Actor.Sheet.Labels.Character.Flaws')
      wrapperClass='flaws-list'
    }}

    <div class='background-field-group'>
      <p class='background-field-group-title'>{{localize 'HONOR_INTRIGUE.Actor.Sheet.Labels.Background.Notes'}}</p>
      {{#if isEditable}}
        {{formField notes.field value=notes.value enriched=notes.enriched toggled=true}}
      {{else}}
        <div class='background-field-group-enriched'>
          {{{notes.enriched}}}
        </div>
      {{/if}}
    </div>
  </div>
</section>
