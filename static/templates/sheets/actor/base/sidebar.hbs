<aside class='sheet-sidebar'>
  <div class='portrait'>
    <img src='{{document.img}}' alt='{{document.name}}' data-action='editImage' data-edit='img'>

    <div class='primary-resources'>
      <div class='resources'>
        <div class='resource-item'>
          <div class='resource-value'>
            {{formInput systemFields.lifeblood.fields.value value=this.system.lifeblood.value type='number' max=this.system.lifeblood.max
                        min=this.system.lifeblood.min}}
            {{#if (ne actorType 'pawn')}}
              <p>/</p>
              {{#if this.system.isLifebloodMightDerived}}
                <p class='resource-value-label'>{{this.system.lifeblood.max}}</p>
              {{else}}
                {{formInput systemFields.lifeblood.fields.max value=this.system.lifeblood.max type='number'}}
              {{/if}}
            {{/if}}
          </div>
          <span class='resource-label'>{{localize 'HONOR_INTRIGUE.Sheet.Labels.Lifeblood'}}</span>
        </div>

        {{#if (or (eq actorType 'hero') (eq actorType 'villain'))}}
          <div class='resource-item'>
            <div class='resource-value'>
              {{formInput systemFields.composure value=this.system.composure type='number' max=systemFields.composure.max}}
              <p>/</p>
              <p class='resource-value-label'>{{systemFields.composure.max}}</p>
            </div>
            <span class='resource-label'>{{localize 'HONOR_INTRIGUE.Sheet.Labels.Composure'}}</span>
          </div>
        {{/if}}
        {{#if (eq actorType 'pawn')}}
          <div class='resource-item'>
            <div class='resource-value'>
              {{formInput systemFields.competence value=this.system.competence type='number'}}
            </div>
            <span class='resource-label'>{{localize 'HONOR_INTRIGUE.Sheet.Labels.Competence'}}</span>
          </div>
        {{/if}}
      </div>
    </div>
  </div>

  <div class='notification-area'>
    {{#if atALoss}}
      <i class='fa-slab fa-regular fa-triangle-exclamation'
         data-title='HONOR_INTRIGUE.EFFECT.Status.AtALoss'
         data-tooltip='HONOR_INTRIGUE.Actor.Sheet.Tooltips.AtALoss'></i>
    {{/if}}
  </div>

  <div class='characteristics'>
    <div class='characteristics-grid-container'>
      <div class='characteristics-grid-container-subgrid'>
        {{> "systems/honor-and-intrigue/templates/api/label-bar.hbs" label="HONOR_INTRIGUE.Sheet.Labels.Qualities"}}

        {{#each this.system.qualities as |quality key|}}
          {{> 'characteristic'
            dotkey=(concat "qualities." key)
            field_type="qualities"
            field_name=key
            rollable=true
          }}
        {{/each}}
      </div>

      <div class='characteristics-grid-container-subgrid'>
        {{> "systems/honor-and-intrigue/templates/api/label-bar.hbs" label="HONOR_INTRIGUE.Sheet.Labels.CombatAbilities"}}

        {{#each this.system.combatAbilities as |ability key|}}
          {{> 'characteristic'
            dotkey=(concat "combatAbilities." key)
            field_type="combatAbilities"
            field_name=key
          }}
        {{/each}}
      </div>

      {{#if hasArcanePower}}
        <div class='characteristics-grid-container-subgrid'>
          {{> "systems/honor-and-intrigue/templates/api/label-bar.hbs" label="HONOR_INTRIGUE.Sheet.Labels.Spellcasting"}}

          <div class='characteristic arcane-power'>
            <div class='arcane-power-value'>
              {{formInput systemFields.arcanePower.fields.value value=system.arcanePower.value max=system.arcanePower.max type='number'}}
              <p>/</p>
              {{formInput systemFields.arcanePower.fields.adjustment value=system.arcanePower.max type='number'}}
            </div>
            <p class='characteristic-label'
               data-tooltip='HONOR_INTRIGUE.Sheet.Hints.ArcanePower'>{{localize 'HONOR_INTRIGUE.Sheet.Labels.ArcanePower'}}</p>
          </div>
        </div>
      {{/if}}
    </div>
  </div>
</aside>

{{#*inline 'characteristic'~}}
  <div class='characteristic'>
    {{#if (and @root.isEditable rollable)}}
      <a class='roll-icon'
         {{#if @root.isEditable}}data-action='rollCharacteristic'{{/if}}
         data-characteristic='{{dotkey}}'
         data-tooltip='HONOR_INTRIGUE.Actor.{{dotkey}}'>
        {{#if @root.useAlternateD10}}
          {{> "systems/honor-and-intrigue/templates/sheets/actor/icons/d10.hbs" }}
        {{else}}
          {{> "systems/honor-and-intrigue/templates/sheets/actor/icons/d6.hbs" }}
        {{/if}}
      </a>
    {{/if}}
    <div class='characteristic-value'>
      {{formInput (@root.getValueField field_type field_name) value=(@root.getValueFieldValue field_type field_name) type='number'}}
    </div>
    <p class='characteristic-label'
       data-tooltip='HONOR_INTRIGUE.Sheet.Hints.{{dotkey}}'>{{localize (concat "HONOR_INTRIGUE.Actor." dotkey)}}</p>
  </div>
{{~/inline}}
