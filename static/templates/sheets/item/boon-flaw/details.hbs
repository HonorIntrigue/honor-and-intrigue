<section class='tab {{tabs.details.id}}{{#if tabs.details.cssClass}} {{tabs.details.cssClass}}{{/if}}'
         data-group='{{tabs.details.group}}'
         data-tab='{{tabs.details.id}}'>
  <div class='tab-content'>
    <div class='new-rule-section'>
      <button type='button' data-action='createRule'>
        <i class='fa-solid fa-plus'></i>
        {{localize 'HONOR_INTRIGUE.Item.Sheet.Labels.Details.CreateRule'}}
      </button>
    </div>

    <div class='scrollable effect-rule-list'>
      {{#each document.effects as |effect|}}
        <div class='effect-item' data-effect-id='{{effect.id}}'>
          <div class='effect-item-name'>
            <input type='text' data-name='name' value='{{effect.name}}'/>
            <button type='button' data-action='deleteRule'>
              <i class='fa-solid fa-trash'></i>
              {{localize 'HONOR_INTRIGUE.Item.Sheet.Labels.Details.DeleteRule'}}
            </button>
          </div>

          <header>
            <div class='key'>{{localize 'EFFECT.ChangeKey'}}</div>
            <div class='mode'>{{localize 'EFFECT.ChangeMode'}}</div>
            <div class='value'>{{localize 'EFFECT.ChangeValue'}}</div>
            <div class='priority'>{{localize 'EFFECT.ChangePriority'}}</div>
            <div class='controls'>
              <button type='button'
                      class='inline-control icon fa-regular fa-square-plus'
                      data-action='addChange'></button>
            </div>
          </header>
          <ol data-changes>
            {{#each effect.changes as |change i|}}
              {{#with ../schema.fields.changes.element.fields as |changeFields|}}
                <li data-index='{{i}}'>
                  <div class='key'>
                    <input type='text' data-name='key' value='{{change.key}}' />
                  </div>
                  <div class='mode'>
                    <select data-name='mode'>
                      {{selectOptions @root.modes selected=change.mode}}
                    </select>
                  </div>
                  <div class='value'>
                    <input type='text' data-name='value' value='{{change.value}}' />
                  </div>
                  <div class='priority'>
                    <input type='number'
                           data-name='priority'
                           min='0'
                           placeholder='{{lookup @root.priorities change.mode}}'
                           value='{{change.priority}}' />
                  </div>
                  <div class='controls'>
                    <button type='button'
                            class='inline-control icon fa-solid fa-trash'
                            data-action='deleteChange'></button>
                  </div>
                </li>
              {{/with}}
            {{/each}}
          </ol>
        </div>
      {{/each}}
    </div>
  </div>
</section>
