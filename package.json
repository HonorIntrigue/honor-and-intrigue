{
  "name": "honor-and-intrigue",
  "description": "A system for the Honor + Intrigue Swashbuckling RPG on Foundry Virtual Tabletop",
  "repository": {
    "type": "git",
    "url": "https://github.com/HonorIntrigue/honor-and-intrigue.git"
  },
  "scripts": {
    "build": "node tools/build.mjs",
    "build:code": "esbuild src/scripts/honor-and-intrigue.mjs --bundle --format=esm --sourcemap --outfile=public/honor-and-intrigue.mjs",
    "build:css": "npx lightningcss --bundle --minify -o public/css/honor-and-intrigue.css static/styles/honor-and-intrigue.css && npx lightningcss --bundle --minify -o public/css/honor-and-intrigue-elements.css static/styles/honor-and-intrigue-elements.css && npx lightningcss --bundle --minify -o public/css/honor-and-intrigue-variables.css static/styles/honor-and-intrigue-variables.css",
    "build:packs": "node ./tools/pullJSONtoLDB.mjs",
    "createSymlinks": "node ./tools/create-symlinks.mjs",
    "dev": "node tools/start-dev.mjs",
    "dev:code": "esbuild src/scripts/honor-and-intrigue.mjs --bundle --format=esm --sourcemap --outfile=public/honor-and-intrigue.mjs --watch",
    "dev:css": "npx chokidar 'static/styles/**/*.css' -c 'pnpm build:css'",
    "dev:setup": "node ./tools/setup-dev.mjs",
    "dev:static": "npx chokidar 'static/**' --ignore 'static/styles/**' -c 'f={path}; d=public/${f#static/}; mkdir -p $(dirname $d); cp $f $d'",
    "lint": "biome check --max-diagnostics 999 src/",
    "lint:fix": "biome check --fix src/",
    "unpack": "node ./tools/pushLDBtoJSON.mjs"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@foundryvtt/foundryvtt-cli": "^3.0.4",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "lightningcss-cli": "^1.32.0",
    "readline": "^1.3.0",
    "typescript": "^7.0.2",
    "wait-on": "^9.0.10"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
